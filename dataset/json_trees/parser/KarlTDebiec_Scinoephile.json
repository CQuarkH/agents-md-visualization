          {
            "id": "rule_1",
            "type": "rule",
            "content": {
              "text": "This repository uses `uv`. Use `uv run` when executing tools.",
              "originalHeader": "Tools"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_2",
            "type": "rule",
            "content": {
              "text": "Run the following checks on only the Python files you have changed or been asked to: `uv run ruff format` `uv run ruff check --fix`",
              "originalHeader": "Tools"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_3",
            "type": "rule",
            "content": {
              "text": "Run `ruff format` only on Python files (do not run it on JSON or other data files).",
              "originalHeader": "Tools"
            },
            "metadata": {
              "strength": "MUST",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_7",
            "type": "rule",
            "content": {
              "text": "Include the standard copyright header at the top of the file.",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_8",
            "type": "rule",
            "content": {
              "text": "Include a module docstring at the top of each file.",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_9",
            "type": "rule",
            "content": {
              "text": "Include `from __future__ import annotations`, unless the file is empty (i.e., contains only copyright headers and module docstrings such as otherwise empty `__init__.py` files).",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_10",
            "type": "rule",
            "content": {
              "text": "Include type annotations for all function and method signatures, with the following exceptions: If a function always returns `None`, omit the return type annotation.",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "MUST",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_11",
            "type": "rule",
            "content": {
              "text": "In `__init__.py` files, only import classes from the module, not functions or variables.",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          },
          {
            "id": "rule_13",
            "type": "rule",
            "content": {
              "text": "Use the `logging` module rather than `print` for any user-facing output in scripts or libraries.",
              "originalHeader": "Code Style"
            },
            "metadata": {
              "strength": "SHOULD",
              "format": "ListItem"
            }
          }
        ]
      },
